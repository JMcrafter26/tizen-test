{
  "name": "@cufiys/tizen-test",
  "version": "0.1.1",
  "description": "Tizen test app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JMcrafter26/tizen-test.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/node": "^25.8.0",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "typescript": "^6.0.2",
    "vite": "^8.0.7"
  },
  "packageType": "app",
  "appName": "Tizen Test",
  "appPath": "index.html",
  "keys": [
    "MediaPlayPause",
    "MediaPlay",
    "MediaPause",
    "MediaStop",
    "MediaTrackPrevious",
    "MediaTrackNext",
    "MediaRewind",
    "MediaFastForward"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "daisyui": "^5.5.19",
    "tailwindcss": "^4.3.0"
  }
}
